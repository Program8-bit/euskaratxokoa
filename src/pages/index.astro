---
import Layout from '../layouts/Layout.astro';
import rankingData from '../data/ranking.json';

const sorted = [...rankingData.participantes].sort((a, b) => b.puntuak - a.puntuak);

const medalak: Record<number, string> = {
  1: '🥇',
  2: '🥈',
  3: '🥉',
};

const podiumColors: Record<number, string> = {
  1: '#f59e0b',
  2: '#94a3b8',
  3: '#cd7c3f',
};
---

<Layout title={`${rankingData.titulo} — ${rankingData.subtitulo}`}>
  <div class="page">

    <!-- HEADER -->
    <header class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <div class="logo-badge">
          <span class="logo-icon">🏆</span>
        </div>
        <h1 class="hero-title">{rankingData.titulo}</h1>
        <p class="hero-sub">{rankingData.subtitulo}</p>
        <span class="season-badge">📅 {rankingData.temporada}</span>
      </div>
    </header>

    <!-- PODIUM TOP 3 -->
    <section class="podium-section">
      <div class="podium">
        {sorted.slice(0, 3).map((p, i) => (
          <div class={`podium-card pos-${i + 1}`} style={`border-color: ${podiumColors[i + 1]}`}>
            <span class="medal">{medalak[i + 1]}</span>
            <div class="podium-rank">#{i + 1}</div>
            <div class="podium-name">{p.izena}</div>
            <div class="podium-points" style={`color: ${podiumColors[i + 1]}`}>
              {p.puntuak} <span class="pts-label">puntu</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FULL TABLE -->
    <section class="table-section">
      <h2 class="section-title">Sailkapen Osoa</h2>
      <div class="table-wrap">
        <table class="ranking-table">
          <thead>
            <tr>
              <th>Postua</th>
              <th>Izen Abizenak</th>
              <th style="text-align: right">Puntuzioa</th>
            </tr>
          </thead>
          <tbody>
            {sorted.map((p, i) => (
              <tr class={i < 3 ? 'top3' : ''}>
                <td class="rank-cell">
                  {i < 3
                    ? <span class="medal-small">{medalak[i + 1]}</span>
                    : <span class="rank-num">{i + 1}</span>
                  }
                </td>
                <td class="name-cell">{p.izena}</td>
                <td class="points-cell" style={i < 3 ? `color: ${podiumColors[i + 1]}` : ''}>
                  {p.puntuak}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <footer class="footer">
      <p>Euskara Txokoa &copy; {rankingData.temporada}</p>
    </footer>
  </div>
</Layout>

<style>
  /* ─── PAGE WRAPPER ─── */
  .page { max-width: 800px; margin: 0 auto; padding: 0 1rem 4rem; }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    text-align: center;
    padding: 4rem 1rem 3rem;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, #1e3a8a33, transparent);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; }
  .logo-badge {
    display: inline-flex; align-items: center; justify-content: center;
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, #1e40af, #7c3aed);
    margin-bottom: 1.25rem;
    box-shadow: 0 0 40px #3b82f644;
  }
  .logo-icon { font-size: 2.4rem; }
  .hero-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 700;
    letter-spacing: .04em;
    background: linear-gradient(90deg, #93c5fd, #c4b5fd, #a5f3fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }
  .hero-sub {
    margin-top: .5rem;
    font-size: 1.1rem;
    color: #94a3b8;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .season-badge {
    display: inline-block;
    margin-top: 1rem;
    padding: .35rem .9rem;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 999px;
    font-size: .85rem;
    color: #94a3b8;
  }

  /* ─── SECTION TITLE ─── */
  .section-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #cbd5e1;
    margin-bottom: 1.5rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid #1e293b;
  }

  /* ─── PODIUM ─── */
  .podium-section { margin-top: 1rem; margin-bottom: 3rem; }
  .podium {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .podium-card {
    flex: 1;
    min-width: 180px;
    max-width: 260px;
    background: #0f172a;
    border: 2px solid;
    border-radius: 16px;
    padding: 1.8rem 1.2rem 1.5rem;
    text-align: center;
    position: relative;
    transition: transform .2s;
  }
  .podium-card:hover { transform: translateY(-4px); }
  .pos-1 { transform: scale(1.05); box-shadow: 0 0 32px #f59e0b33; }
  .pos-1:hover { transform: scale(1.05) translateY(-4px); }
  .medal { font-size: 2.4rem; display: block; margin-bottom: .5rem; }
  .podium-rank {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    color: #64748b;
    margin-bottom: .4rem;
  }
  .podium-name {
    font-family: 'Oswald', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: .6rem;
  }
  .podium-points {
    font-family: 'Oswald', sans-serif;
    font-size: 2rem;
    font-weight: 700;
  }
  .pts-label { font-size: 1rem; font-weight: 400; color: #64748b; }

  /* ─── TABLE ─── */
  .table-section { margin-bottom: 3rem; }
  .table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid #1e293b; }
  .ranking-table {
    width: 100%;
    border-collapse: collapse;
  }
  .ranking-table thead th {
    background: #0f172a;
    padding: .9rem 1rem;
    text-align: left;
    font-family: 'Oswald', sans-serif;
    font-size: .85rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #64748b;
    border-bottom: 1px solid #1e293b;
  }
  .ranking-table tbody tr {
    border-bottom: 1px solid #0f172a;
    transition: background .15s;
  }
  .ranking-table tbody tr:hover { background: #0f172a88; }
  .ranking-table tbody tr.top3 { background: #0f172a66; }
  .ranking-table td {
    padding: .8rem 1rem;
    vertical-align: middle;
  }
  .rank-cell { width: 56px; }
  .rank-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #1e293b;
    font-size: .85rem;
    color: #64748b;
    font-weight: 600;
  }
  .medal-small { font-size: 1.4rem; }
  .name-cell {
    font-weight: 600;
    color: #f1f5f9;
    font-size: 1rem;
  }
  .points-cell {
    font-family: 'Oswald', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #94a3b8;
    text-align: right;
  }

  /* ─── FOOTER ─── */
  .footer {
    text-align: center;
    padding: 1.5rem;
    font-size: .8rem;
    color: #334155;
    border-top: 1px solid #1e293b;
  }
</style>
